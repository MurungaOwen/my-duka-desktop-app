# Core app mode (optional)
MYDUKA_MODE=standalone

# Optional override. Default is ./myduka.sqlite in project root
MYDUKA_DB_PATH=./myduka.sqlite

# Auto-seed demo data on first launch when no staff users exist
MYDUKA_AUTO_SEED=true

# Seeder groups (used when calling SeedDemoData / cmd/seed)
# Set to false to skip specific seed group.
MYDUKA_SEED_SETTINGS=true
MYDUKA_SEED_USERS=true
MYDUKA_SEED_CATEGORIES=true
MYDUKA_SEED_SUPPLIERS=true
MYDUKA_SEED_PRODUCTS=true
MYDUKA_SEED_PURCHASE_ORDERS=true
MYDUKA_SEED_SALES=true

# Paystack server-side secret key (required for real M-Pesa charges)
# Use sk_test_* for testing, sk_live_* for production
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# POS merchant email sent to Paystack when creating charges (required)
PAYSTACK_POS_EMAIL=sales@yourshop.co.ke

# Optional: normally keep default
PAYSTACK_BASE_URL=https://api.paystack.co
